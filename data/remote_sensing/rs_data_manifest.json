        "evi_anomaly"
      ],
      "rows": 504
    },
    "lst_monthly.csv": {
      "variables": [
        "lst",
        "lst_anomaly",
        "lst_drought_index"
      ],
      "rows": 504
    },
    "drought_index_monthly.csv": {
      "variables": [
        "vhi",
        "spi",
        "drought_index",
        "ndwi"
      ],
      "rows": 504
    }
  },
  "preprocessing": [
    "去云处理",
    "空间插值",
    "省级行政单元聚合",
